# Aurion Shift Handover — environment variables
# Copy to .env.local and fill in. Never commit .env.local. (CLAUDE.md)

# --- Supabase (public — safe in the browser) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# Publishable / anon key. Browser uses this only.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Supabase (SERVER ONLY — never expose to the browser) ---
# Service role bypasses RLS. Used only in server routes (e.g. Sheets sync).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Google Sheets sync (handover only, SERVER ONLY) ---
GOOGLE_SA_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# Private key with literal \n escapes (one line). Used by /api/sync-handover.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Bare Sheet ID only (the part between /d/ and /edit in the share URL).
HANDOVER_SHEET_ID="your-sheet-id"

# --- Auth: seed admins (used once by scripts/seed-admins.mjs) ---
ADMIN1_EMAIL="admin1@example.com"
ADMIN1_PASSWORD="generate-a-strong-password"
ADMIN1_NAME="Admin One"
ADMIN2_EMAIL="admin2@example.com"
ADMIN2_PASSWORD="generate-a-strong-password"
ADMIN2_NAME="Admin Two"

# --- Web Push (VAPID) — server sends push to receptionists ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:you@example.com"

# --- Google Drive (per-hotel handover PDF archive; same SA as Sheets) ---
DRIVE_FOLDER_AL_AQEEQ="drive-folder-id"
DRIVE_FOLDER_AS_SALAAM="drive-folder-id"

# --- Legacy manager passcode (superseded by Auth; optional) ---
MANAGER_PASSCODE="choose-a-passcode"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:5174"
# Default UI language for first paint: 'en' or 'ar'.
NEXT_PUBLIC_DEFAULT_LANG="ar"

# --- Optional: cash-mismatch email alert (Resend — final/optional phase) ---
# If set, a completed handover with a cash variance ≠ 0 emails the manager.
# RESEND_API_KEY="re_..."
# ALERT_FROM_EMAIL="alerts@yourdomain.com"
# MANAGER_ALERT_EMAIL="manager@yourdomain.com"
